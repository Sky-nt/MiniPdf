<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:MiniPdf.Gui.ViewModels"
        x:Class="MiniPdf.Gui.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="MiniPdf — Office to PDF Converter"
        Width="800" Height="560"
        MinWidth="600" MinHeight="400"
        DragDrop.AllowDrop="True">

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <DockPanel Margin="12">

        <!-- Top toolbar -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
            <Button Content="📂 Open Files" Click="OnOpenFilesClick" />
            <Button Content="📁 Open Folder" Click="OnOpenFolderClick" />
            <Button Content="🗑 Clear" Command="{Binding ClearFilesCommand}" />
            <Separator Width="1" Margin="4,0" />
            <TextBlock Text="Font Dir:" VerticalAlignment="Center" />
            <TextBox Text="{Binding FontDirectory}" Width="200" Watermark="(optional)" />
            <Button Content="..." Click="OnBrowseFontDirClick" Width="32" />
        </StackPanel>

        <!-- Bottom status bar -->
        <Grid DockPanel.Dock="Bottom" ColumnDefinitions="*,Auto" Margin="0,12,0,0">
            <StackPanel Spacing="4">
                <ProgressBar Value="{Binding Progress}" Maximum="100" Height="6" />
                <TextBlock Text="{Binding StatusText}" FontSize="12" Foreground="Gray" />
            </StackPanel>
            <Button Grid.Column="1"
                    Content="▶ Convert All"
                    Command="{Binding ConvertAllCommand}"
                    Classes="accent"
                    FontWeight="Bold"
                    Padding="24,8"
                    VerticalAlignment="Top" />
        </Grid>

        <!-- File list -->
        <Border BorderBrush="#D0D0D0" BorderThickness="1" CornerRadius="4"
                DragDrop.AllowDrop="True">
            <Grid>
                <!-- Drop overlay (shown when list is empty) -->
                <TextBlock Text="Drag &amp; drop DOCX / XLSX files here"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="#B0B0B0"
                           FontSize="16"
                           IsVisible="{Binding !Files.Count}" />

                <DataGrid ItemsSource="{Binding Files}"
                          AutoGenerateColumns="False"
                          CanUserReorderColumns="False"
                          CanUserResizeColumns="True"
                          CanUserSortColumns="False"
                          IsReadOnly="True"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="File" Binding="{Binding FileName}" Width="2*" />
                        <DataGridTextColumn Header="Type" Binding="{Binding FileType}" Width="60" />
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100" />
                        <DataGridTextColumn Header="Output" Binding="{Binding OutputPath}" Width="2*" />
                        <DataGridTemplateColumn Header="" Width="70">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate x:DataType="vm:FileItem">
                                    <StackPanel Orientation="Horizontal" Spacing="2" HorizontalAlignment="Center">
                                        <Button Content="📂"
                                                Click="OnOpenOutputClick"
                                                Tag="{Binding}"
                                                IsVisible="{Binding OutputPath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                Background="Transparent"
                                                ToolTip.Tip="Open output folder"
                                                Padding="4,2"
                                                FontSize="11" />
                                        <Button Content="✕"
                                                Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).RemoveFileCommand}"
                                                CommandParameter="{Binding}"
                                                Background="Transparent"
                                                Padding="4,2"
                                                FontSize="11" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

    </DockPanel>
</Window>
